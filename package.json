{
  "name": "tinbase",
  "version": "0.9.0",
  "description": "A Docker-free, Supabase-compatible local backend — real Postgres (embedded native or PGlite/WASM), wire-compatible with supabase-js.",
  "type": "module",
  "author": "Sanket Sahu",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "tinbase": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets/logo.svg"
  ],
  "scripts": {
    "build": "npm run build:admin && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:binary": "npm run build && bun build --compile src/cli.ts --outfile dist-bin/tinbase --external @electric-sql/pglite --define 'process.env.TINBASE_SINGLE_BINARY=\"1\"'",
    "prepublishOnly": "npm run build && npm test",
    "build:admin": "cd admin-ui && npm run build",
    "parity": "tsx parity/harness.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "supabase",
    "pglite",
    "postgrest",
    "pocketbase",
    "wasm",
    "postgres"
  ],
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinbase/tinbase.git"
  },
  "homepage": "https://tinbase.vercel.app",
  "bugs": {
    "url": "https://github.com/tinbase/tinbase/issues"
  },
  "optionalDependencies": {
    "pg-mem": "npm:@tinbase/pg-mem@^3.2.0",
    "esbuild": "^0.28.0"
  }
}
